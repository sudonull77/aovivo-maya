{
    "version": 2,
    "public": true,
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/aovivo.apk",
            "headers": [
                { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
                { "key": "Content-Disposition", "value": "attachment" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" }
            ]
        }
    ]
}
